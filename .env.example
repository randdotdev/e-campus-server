# Server
PORT=8080
ENV=development
LOG_LEVEL=debug

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=ecampus
DB_PASSWORD=ecampus_dev
DB_NAME=ecampus
DB_SSLMODE=disable

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-256-bit-secret-change-in-production-minimum-32-chars
JWT_ACCESS_TTL=1h
JWT_REFRESH_TTL=168h

# Storage (MinIO for local dev)
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=ecampus
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_USE_SSL=false

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_RPS=100
RATE_LIMIT_BURST=20
